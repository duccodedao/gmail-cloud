rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Basic helper function to check if user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Check if the user is an authorized admin based on email
    function isAdmin() {
      return isSignedIn() && 
             (request.auth.token.email == 'sonlyhongduc@gmail.com' || 
              request.auth.token.email == 'sonlyhongduc1@ghn.vn');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation Helpers
    function isValidGmailAccount(data) {
      return data.id is string && 
             data.email is string && 
             data.status in ["ACTIVE", "UNUSED", "IN_USE", "LOCKED", "SUSPENDED"] &&
             data.createdAt is string && data.updatedAt is string &&
             (data.get('lastPeerMeetAt', '') is string);
    }

    function isValidVaultItem(data) {
      return data.id is string && 
             data.account is string && 
             data.webName is string && 
             data.createdAt is string && data.updatedAt is string;
    }

    // Rules for Gmail Accounts
    match /gmail_accounts/{accountId} {
      allow read: if isAdmin();
      allow create: if isAdmin() && isValidGmailAccount(incoming());
      allow update: if isAdmin() && isValidGmailAccount(incoming()) && 
                    incoming().id == existing().id &&
                    incoming().createdAt == existing().createdAt;
      allow delete: if isAdmin();
    }

    // Rules for Web Vault
    match /web_vault/{vaultId} {
      allow read: if isAdmin();
      allow create: if isAdmin() && isValidVaultItem(incoming());
      allow update: if isAdmin() && isValidVaultItem(incoming()) && 
                    incoming().id == existing().id &&
                    incoming().createdAt == existing().createdAt;
      allow delete: if isAdmin();
    }
  }
}
